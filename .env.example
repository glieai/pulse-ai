# ── Pulse Configuration ──────────────────────────────────────────

# Mode: "solo" for self-hosted single user (default)
PULSE_MODE=solo

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse

# ── Security ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=  # Generate with: openssl rand -base64 32

# ── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── LLM (optional — for AI-powered features) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# PULSE_LLM_PROVIDER=anthropic
# PULSE_LLM_MODEL=claude-sonnet-4-20250514
